# ══════════════════════════════════════════════════════════════════════════════
#  OncoHack — конфигурация LLM провайдеров
#  Скопируйте этот файл в .env и заполните нужные значения:
#      cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Основной LLM (анализ PK-данных и выбор дизайна) ───────────────────────────
# Значения: ollama | groq | gemini | claude | yandex | mock
LLM_PROVIDER=yandex

# ── Ollama (запускается в Docker — API ключ не нужен) ─────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral

# ── Groq (бесплатно, быстро — https://console.groq.com) ──────────────────────
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Gemini (бесплатно — https://ai.google.dev) ────────────────────────
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic Claude (платно, лучшее качество) ───────────────────────────────
CLAUDE_API_KEY=your_claude_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Yandex Cloud Foundation Models (AI Studio) ────────────────────────────────
# Консоль: https://console.yandex.cloud/
# API-ключ: IAM → Сервисные аккаунты → выбрать аккаунт → API-ключи → Создать
# Folder ID: главная страница консоли (справа под именем каталога)
# Модели: yandexgpt-lite | yandexgpt | yandexgpt-32k
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here
YANDEX_MODEL=yandexgpt/latest

# ── LLM для перевода обоснования на русский язык ─────────────────────────────
# Значения: groq | gemini | claude | ollama | yandex | same
# "same" — использовать тот же провайдер, что и LLM_PROVIDER
TRANSLATE_PROVIDER=same
